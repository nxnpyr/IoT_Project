<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Smart Rice Bin</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="container" style="display: flex; height: 90vh; align-items: center;">
        <div class="card p-5 mx-auto shadow-sm" style="max-width: 450px; width: 100%; border-radius: 25px; background: var(--card-bg);">
            
            <div class="text-center mb-4">
                <div class="icon-circle mx-auto mb-3" style="width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: var(--input-bg); color: var(--primary-green);">
                    <i class="fas fa-key fa-2x"></i>
                </div>
                <h5 class="fw-bold" style="color: var(--text-main);">รีเซ็ตรหัสผ่าน</h5>
                <p class="text-muted small">ระบุเบอร์โทรและรหัสถังเพื่อตั้งรหัสผ่านใหม่</p>
            </div>

            <div class="mb-3">
                <label class="small text-muted">เบอร์โทรศัพท์ที่ลงทะเบียน</label>
                <input type="tel" id="fPhone" class="form-control border-0 bg-light p-3" style="border-radius: 12px;" placeholder="08x-xxx-xxxx">
            </div>

            <div class="mb-3">
                <label class="small text-muted">Serial Number (รหัสถัง)</label>
                <input type="text" id="fSerial" class="form-control border-0 bg-light p-3" style="border-radius: 12px;" placeholder="SRB-XXX">
            </div>

            <hr class="my-4" style="border-color: var(--border-color);">

            <div class="mb-4">
                <label class="small text-muted">รหัสผ่านใหม่ (A-Z, a-z, 0-9)</label>
                <input type="password" id="fNewPass" class="form-control border-0 bg-light p-3" style="border-radius: 12px;" placeholder="••••••••">
            </div>

            <button onclick="resetPass()" id="btnReset" class="btn btn-success w-100 p-3 mb-3 shadow-sm" style="border-radius: 15px; background-color: var(--primary-green); border: none; font-weight: 500;">
                เปลี่ยนรหัสผ่าน
            </button>
            
            <div class="text-center">
                <a href="/smartbin" class="text-muted small text-decoration-none">
                    <i class="fas fa-chevron-left me-1"></i> ย้อนกลับไปหน้าเข้าสู่ระบบ
                </a>
            </div>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
    <script>
        /**
         * 1. Firebase Configuration
         */
        const firebaseConfig = {
            apiKey: "AIzaSyCzVD8KRML-BNyvmqGMlyFmFxpg-VU0pqo",
            authDomain: "iot-a8afd.firebaseapp.com",
            databaseURL: "https://iot-a8afd-default-rtdb.asia-southeast1.firebasedatabase.app",
            projectId: "iot-a8afd",
            storageBucket: "iot-a8afd.firebasestorage.app",
            messagingSenderId: "895547899276",
            appId: "1:895547899276:web:17131cbcc67a1de256eaa9"
        };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        /**
         * 2. Theme Management (รองรับ Dark Mode)
         */
        const savedTheme = localStorage.getItem("theme") || "light";
        document.documentElement.setAttribute("data-theme", savedTheme);

        /**
         * 3. Reset Password Logic
         */
        function resetPass() {
            const phone = document.getElementById("fPhone").value;
            const serial = document.getElementById("fSerial").value;
            const newP = document.getElementById("fNewPass").value;
            const btn = document.getElementById("btnReset");

            // ตรวจสอบความถูกต้องของรหัสผ่าน (Regex: A-Z, a-z, 0-9 และ 8 ตัวขึ้นไป)
            const passRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)[a-zA-Z\d]{8,}$/;

            if(!phone || !serial || !newP) return alert("กรุณากรอกข้อมูลให้ครบทุกช่อง");
            if(!passRegex.test(newP)) return alert("รหัสผ่านใหม่ต้องมี 8 ตัวขึ้นไป ประกอบด้วย A-Z, a-z และ 0-9");

            btn.disabled = true;
            btn.innerText = "กำลังดำเนินการ...";

            // ค้นหาผู้ใช้จากเบอร์โทรศัพท์
            db.ref('Users').orderByChild('phone').equalTo(phone).once("value", snap => {
                if(snap.exists()) {
                    const key = Object.keys(snap.val())[0];
                    const userData = snap.val()[key];

                    // ตรวจสอบว่า Serial Number ตรงกับที่ลงทะเบียนไว้หรือไม่
                    if(userData.serial === serial) {
                        db.ref(`Users/${key}`).update({ 
                            password: newP 
                        }).then(() => {
                            alert("เปลี่ยนรหัสผ่านสำเร็จ! กรุณาเข้าสู่ระบบด้วยรหัสผ่านใหม่");
                            window.location.href = "/smartbin";
                        });
                    } else {
                        alert("รหัส Serial Number ไม่ถูกต้อง");
                        btn.disabled = false;
                        btn.innerText = "เปลี่ยนรหัสผ่าน";
                    }
                } else {
                    alert("ไม่พบเบอร์โทรศัพท์นี้ในระบบ");
                    btn.disabled = false;
                    btn.innerText = "เปลี่ยนรหัสผ่าน";
                }
            }).catch(err => {
                alert("เกิดข้อผิดพลาด: " + err.message);
                btn.disabled = false;
            });
        }
    </script>
</body>
</html>